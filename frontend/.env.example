# Expo public env vars (must be prefixed with EXPO_PUBLIC_ to be available in app code)
# This is the URL where your backend API runs.
# - For Mac dev with iPhone via Expo Go: use Mac LAN IP (run `ipconfig getifaddr en0` on Mac)
# - For local web/simulator only: http://localhost:8000

EXPO_PUBLIC_API_URL=http://192.168.1.55:8000
